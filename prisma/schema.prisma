generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  name                String
  email               String              @unique
  role                String
  password            String              @default("$2a$10$cwW.O.C.O.C.O.C.O.C.O.C.O.C.O.C.O.C.O.C.O.C.O.C.O.C.O")
  avatarUrl           String?
  code                String?             @unique
  phoneNumber         String?
  schoolName          String?
  bio                 String?
  classId             String?
  xp                  Int                 @default(0)
  level               Int                 @default(1)
  streak              Int                 @default(0)
  lastSubmissionDate  DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  announcements       Announcement[]
  createdAssignments  Assignment[]
  attendanceRecords   AttendanceRecord[]
  badges              Badge[]
  behaviorRecords     BehaviorRecord[]
  classes             Class[]             @relation("TeacherClasses")
  enrollments         ClassEnrollment[]
  uploadedResources   ClassResource[]
  classSessions       ClassSession[]
  comments            Comment[]
  guardian            Guardian?
  missions            Mission[]
  notifications       Notification[]
  personalEvents      PersonalEvent[]
  reactions           Reaction[]
  socialEvents        SocialEvent[]
  studentGuardians    StudentGuardian[]   @relation("StudentGuardians")
  submissions         Submission[]
  worksheetProgresses WorksheetProgress[]
  teachingSubjects    String?
  preferences         String?
}

model Class {
  id                String            @id @default(cuid())
  name              String
  subject           String
  description       String?
  teacherId         String
  schedule          String?
  avatar            String?
  code              String            @unique
  role              String            @default("extra")
  grade             String?
  codeEnabled       Boolean           @default(true)
  maxStudents       Int               @default(45)
  color             String            @default("blue")
  classType         String            @default("NORMAL")
  tuitionFee        Int?
  startDate         DateTime?
  stream            String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  announcements     Announcement[]
  assignmentClasses AssignmentClass[]
  behaviorRecords   BehaviorRecord[]
  teacher           User              @relation("TeacherClasses", fields: [teacherId], references: [id])
  enrollments       ClassEnrollment[]
  resources         ClassResource[]
  classSessions     ClassSession[]
  settings          ClassSettings?
}

model Announcement {
  id          String     @id @default(cuid())
  classId     String
  teacherId   String
  content     String
  title       String?
  type        String     @default("NORMAL")
  tags        String?
  isPinned    Boolean    @default(false)
  attachments String?    @default("[]")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  teacher     User       @relation(fields: [teacherId], references: [id])
  class       Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  comments    Comment[]
  reactions   Reaction[]

  @@index([classId, createdAt(sort: Desc)])
  @@index([isPinned])
}

model Comment {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id])
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
}

model ClassResource {
  id          String   @id @default(cuid())
  classId     String
  title       String
  description String?
  fileUrl     String
  fileType    String
  fileSize    Int
  uploadedBy  String
  folderId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  uploader    User     @relation(fields: [uploadedBy], references: [id])
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([uploadedBy])
}

model ClassEnrollment {
  id                   String    @id @default(cuid())
  userId               String
  classId              String
  role                 String    @default("student")
  joinedAt             DateTime  @default(now())
  status               String    @default("active")
  isPinned             Boolean   @default(false)
  updatedAt            DateTime  @default(now()) @updatedAt
  mutedUntil           DateTime?
  notificationsEnabled Boolean   @default(true)
  class                Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
  @@index([userId])
  @@index([classId])
  @@index([status])
}

model ClassSettings {
  id                       String   @id @default(cuid())
  classId                  String   @unique
  announcementPermission   String   @default("TEACHER_ONLY")
  attachmentPermission     String   @default("TEACHER_ONLY")
  allowComments            Boolean  @default(true)
  allowReactions           Boolean  @default(true)
  defaultMaxScore          Int      @default(10)
  allowLateSubmission      Boolean  @default(true)
  latePenaltyPercent       Int      @default(10)
  autoReminder             Boolean  @default(true)
  reminderDaysBefore       Int      @default(1)
  resourceUploadPermission String   @default("TEACHER_ONLY")
  maxFileSizeMB            Int      @default(50)
  requireApproval          Boolean  @default(false)
  allowStudentDirectory    Boolean  @default(true)
  hideGradesFromStudents   Boolean  @default(false)
  showGradeStatistics      Boolean  @default(true)
  emailNotifications       Boolean  @default(true)
  pushNotifications        Boolean  @default(true)
  newAnnouncementNotify    Boolean  @default(true)
  newAssignmentNotify      Boolean  @default(true)
  deadlineReminderNotify   Boolean  @default(true)
  gradePostedNotify        Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  class                    Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model Assignment {
  id                String              @id @default(cuid())
  title             String
  description       String
  dueDate           DateTime
  teacherId         String
  status            String              @default("open")
  type              String              @default("exercise")
  xpReward          Int                 @default(100)
  subject           String?
  maxScore          Int?
  classIds          String?
  attachments       String?
  rubric            String?
  aiSettings        String?
  isPhysical        Boolean             @default(false)
  worksheetCode     String?
  worksheetFileUrl  String?
  worksheetFileType String?
  isWorksheetMode   Boolean             @default(false)
  requirePhoto      Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  teacher           User                @relation(fields: [teacherId], references: [id])
  assignmentClasses AssignmentClass[]
  submissions       Submission[]
  worksheetProgress WorksheetProgress[]
}

model WorksheetProgress {
  id              String     @id @default(cuid())
  assignmentId    String
  studentId       String
  status          String     @default("not_started")
  viewedAt        DateTime?
  completedAt     DateTime?
  photoUrl        String?
  photoUploadedAt DateTime?
  hintsUsed       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  student         User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId, status])
}

model Submission {
  id            String     @id @default(cuid())
  assignmentId  String
  studentId     String
  content       String
  submittedAt   DateTime   @default(now())
  status        String     @default("submitted")
  score         Float?
  feedback      String?
  attachments   String?
  errorAnalysis String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  student       User       @relation(fields: [studentId], references: [id])
  assignment    Assignment @relation(fields: [assignmentId], references: [id])
}

model Mission {
  id                  String    @id @default(cuid())
  title               String
  description         String
  type                String
  category            String
  createdBy           String
  assignedTo          String
  relatedAssignmentId String?
  relatedClassId      String?
  dueDate             DateTime?
  status              String    @default("pending")
  completedAt         DateTime?
  xpReward            Int?
  progress            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [assignedTo], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  icon        String
  description String
  earnedAt    DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model SocialEvent {
  id        String     @id @default(cuid())
  type      String
  userId    String
  content   String
  timestamp DateTime   @default(now())
  xpGained  Int?
  classId   String
  reactions Reaction[]
  user      User       @relation(fields: [userId], references: [id])
}

model Reaction {
  id             String        @id @default(cuid())
  socialEventId  String?
  announcementId String?
  userId         String
  type           String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement   Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  socialEvent    SocialEvent?  @relation(fields: [socialEventId], references: [id], onDelete: Cascade)
}

model ClassSession {
  id                String             @id @default(cuid())
  classId           String
  teacherId         String
  date              DateTime
  period            Int
  subject           String?
  lessonContent     String?
  note              String?
  classification    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
  teacher           User               @relation(fields: [teacherId], references: [id])
  class             Class              @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([date])
}

model AttendanceRecord {
  id        String       @id @default(cuid())
  sessionId String
  studentId String
  status    String       @default("PRESENT")
  note      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  student   User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session   ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([studentId])
}

model BehaviorRecord {
  id          String   @id @default(cuid())
  studentId   String
  classId     String
  type        String
  description String
  scoreChange Int
  recordedBy  String
  createdAt   DateTime @default(now())
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([classId])
}

model Guardian {
  id        String            @id @default(cuid())
  userId    String            @unique
  phone     String?
  zaloId    String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  students  StudentGuardian[]
}

model StudentGuardian {
  studentId    String
  guardianId   String
  relationship String
  isPrimary    Boolean  @default(false)
  guardian     Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student      User     @relation("StudentGuardians", fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, guardianId])
}

model AssignmentClass {
  assignmentId String
  classId      String
  dueDate      DateTime?
  config       String?
  class        Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@id([assignmentId, classId])
}

model PersonalEvent {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  color       String   @default("blue")
  isAllDay    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startTime])
}

model FocusSession {
  id          String   @id @default(cuid())
  userId      String
  duration    Int // in seconds
  type        String   @default("review") // review, homework, reading, notes
  subject     String?
  goal        String?
  completedAt DateTime @default(now())
  isCompleted Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([completedAt])
  @@index([userId, completedAt])
}
